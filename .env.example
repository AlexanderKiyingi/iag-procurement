# Local development — see config/.env.production.example for production.
# Copy to `.env` in this directory.

ENVIRONMENT=development
SERVICE_NAME=procurement
PORT=4009
GIN_MODE=debug

DATABASE_URL=postgres://svc_iag_procurement:iag_procurement_dev@localhost:5432/iag_platform?sslmode=disable
REDIS_URL=redis://127.0.0.1:6379/3
AUTO_MIGRATE=true
SEED_ON_STARTUP=false
SEED_CACHE_TTL_SECONDS=30
CORS_ALLOW_ORIGIN=http://localhost:3000

# Platform auth (default) — same secret as api-gateway; permissions from iag-authentication.
AUTH_MODE=gateway
GATEWAY_INTERNAL_SECRET=dev-gateway-secret-min-16-chars
JWT_ISSUER=http://localhost:3001
JWKS_URL=http://127.0.0.1:3001/.well-known/jwks.json

# Legacy local JWT (AUTH_MODE=legacy only)
# JWT_SECRET=dev-insecure-change-me
# JWT_TTL_HOURS=72
# DEFAULT_ADMIN_PASSWORD=changeme

# Leave SMTP_HOST empty to use NoopMailer (in-app notifications still work).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=procurement@localhost

NOTIFY_QUEUE_KEY=procurement:notify:queue
NOTIFY_CONSUMER_WORKERS=2
SIGNAL_REDIS_CHANNEL=procurement:signals

# Kafka — PM requisition consumer (iag.commercial)
EVENT_BUS_ENABLED=true
KAFKA_BROKERS=localhost:19092
KAFKA_COMMERCIAL_TOPIC=iag.commercial
KAFKA_CONSUMER_GROUP=iag.procurement.commercial
