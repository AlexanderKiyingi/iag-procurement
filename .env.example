# Local development — see config/.env.production.example for production.
# Copy to `.env` in this directory.

ENVIRONMENT=development
SERVICE_NAME=procurement
PORT=4009
GIN_MODE=debug

DATABASE_URL=postgres://svc_iag_procurement:iag_procurement_dev@localhost:5432/iag_platform?sslmode=disable
REDIS_URL=redis://127.0.0.1:6379/3
AUTO_MIGRATE=true
SEED_ON_STARTUP=false
SEED_CACHE_TTL_SECONDS=30
CORS_ALLOW_ORIGIN=http://localhost:3000,http://localhost:5173
# Aliases: CORS_ORIGIN, ALLOWED_ORIGINS

# Platform auth — hard cutover to Bearer+aud.
# AUTH_MODE: jwt (default; Bearer JWT verified via JWKS, aud=iag.procurement)
#          | legacy (local DB-backed users + HS256; standalone app only,
#                    rejected in production)
AUTH_MODE=jwt
JWT_ISSUER=http://localhost:3001
JWKS_URL=http://127.0.0.1:3001/.well-known/jwks.json
AUDIENCE=iag.procurement

# Purchase orders at/above this total are created "Pending Approval"; below it
# they are auto-"Approved" (and so are POs from awarded RFQs). 0 = every PO
# requires approval.
PROCUREMENT_APPROVAL_THRESHOLD=0

# Legacy local JWT (AUTH_MODE=legacy only)
# JWT_SECRET=dev-insecure-change-me
# JWT_TTL_HOURS=72
# DEFAULT_ADMIN_PASSWORD=changeme

# Central notifications service (iag-notifications). Leave NOTIFICATIONS_URL
# empty to use a logging-only Noop dispatcher (in-app rows still land in
# Postgres). When set, the four NOTIFICATIONS_* vars below are required;
# AUTH_TOKEN_URL defaults to JWT_ISSUER + /oauth/token.
NOTIFICATIONS_URL=
NOTIFICATIONS_CLIENT_ID=
NOTIFICATIONS_CLIENT_SECRET=
NOTIFICATIONS_AUDIENCE=iag.notifications
AUTH_TOKEN_URL=

# Service account — registers procurement.* permissions with iag-authentication (jwt mode).
SERVICE_CLIENT_ID=iag-procurement
SERVICE_CLIENT_SECRET=

SIGNAL_REDIS_CHANNEL=procurement:signals

# Kafka — PM requisition consumer (iag.commercial)
EVENT_BUS_ENABLED=true
KAFKA_BROKERS=localhost:19092
KAFKA_COMMERCIAL_TOPIC=iag.commercial
KAFKA_SUPPLY_CHAIN_TOPIC=iag.supply-chain
KAFKA_CONSUMER_GROUP=iag.procurement.commercial
KAFKA_SUPPLY_CHAIN_GROUP=iag.procurement.supply-chain
