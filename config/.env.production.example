# Production — behind iag-api-gateway with platform JWT.
ENVIRONMENT=production
SERVICE_NAME=procurement
PORT=4009
# Railway: health checks use PORT; app and /app/healthcheck read PORT.
GIN_MODE=release

DATABASE_URL=postgres://svc_iag_procurement:PASSWORD@HOST:5432/iag_platform?sslmode=require
REDIS_URL=redis://redis:6379/3
AUTO_MIGRATE=true
SEED_ON_STARTUP=false

CORS_ALLOW_ORIGIN=https://app.example.com

AUTH_MODE=jwt
JWT_ISSUER=https://auth.example.com
JWKS_URL=https://auth.example.com/.well-known/jwks.json
AUDIENCE=iag.procurement

# Notifications — email is dispatched via the central iag-notifications
# service. Register a client_credentials OAuth client (iag-procurement)
# in iag-authentication with audience=iag.notifications and the
# platform.add_servicecall permission, then fill in the four
# NOTIFICATIONS_* values. AUTH_TOKEN_URL defaults to JWT_ISSUER +
# /oauth/token if left blank.
NOTIFICATIONS_URL=https://iag-notifications-production.up.railway.app
NOTIFICATIONS_CLIENT_ID=iag-procurement
NOTIFICATIONS_CLIENT_SECRET=
NOTIFICATIONS_AUDIENCE=iag.notifications
AUTH_TOKEN_URL=

SIGNAL_REDIS_CHANNEL=procurement:signals

EVENT_BUS_ENABLED=true
KAFKA_BROKERS=kafka:9092
KAFKA_COMMERCIAL_TOPIC=iag.commercial
KAFKA_CONSUMER_GROUP=iag.procurement.commercial
